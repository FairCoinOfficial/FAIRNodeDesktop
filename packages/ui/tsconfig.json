{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist-types",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "paths": {
      "@common/*": ["../common/src/*"]
    }
  },
  "include": ["src/**/*", "index.html"],
  "exclude": ["dist"],
  "references": [{ "path": "../common" }]
}
